# Ensure shell scripts are always checked out with LF endings.
# Without this, Windows autocrlf can turn *.sh files into CRLF, breaking
# bash on Linux (`bad interpreter: /usr/bin/env\r`).
*.sh                text eol=lf
build/scripts/*.sh  text eol=lf

# PowerShell / batch stays platform-native (Windows-only tools).
*.ps1               text eol=crlf
*.bat               text eol=crlf
*.cmd               text eol=crlf

# Everything else uses git's auto-detection.
* text=auto
